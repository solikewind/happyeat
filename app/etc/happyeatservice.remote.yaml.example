# Production override config for Docker deployment.
# Copy this file to app/etc/happyeatservice.remote.yaml（与 docker-compose-prod 中 -f 路径一致）并填写真实值。
#
# 请求体大小：生产 compose 使用本文件而非 happyeatservice.yaml；若此处不写 MaxBytes，go-zero 默认仅 1MB。
# 前端经 Nginx /api 代理时，还须把 Nginx client_max_body_size 调到 ≥ 此处（见 happyeat-web deploy 工作流）。

MaxBytes: 5242880

Auth:
  AccessSecret: "replace-with-strong-jwt-secret"
  AccessExpire: 86400

SqlConfig:
  DataSource: "postgres://postgres:replace-db-password@postgres:5432/happyeat?sslmode=disable"

llm:
  APIKey: ""
  BaseURL: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  Model: "qwen-plus"

asr:
  APIKey: ""
  BaseURL: "https://dashscope.aliyuncs.com/api/v1"
  Model: "paraformer-realtime-v2"
  TranscribePath: "/asr/transcribe"
  HotwordCreatePath: "/asr/hotwords"

# 商鹏厨房小票（可选）：库内金额若为「分」可设 kitchen_ticket_amount_scale: cent
# spyun:
#   enabled: true
#   app_id: ""
#   app_secret: ""
#   sn: ""
#   kitchen_ticket_amount_scale: cent
